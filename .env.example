# Supabase (from supabase.com → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Upstash Redis (from upstash.com → your DB → REST API)
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# Google Maps (from console.cloud.google.com → Credentials)
EXPO_PUBLIC_GOOGLE_MAPS_KEY=AIza...

# TomTom (from developer.tomtom.com → My Apps)
TOMTOM_API_KEY=xxxx

# Sentry (from sentry.io → your project → DSN)
EXPO_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/xxxx

# Cab providers (fill in as you get approved)
UBER_CLIENT_ID=
UBER_CLIENT_SECRET=
BOLT_API_KEY=
FREENOW_CLIENT_ID=
FREENOW_CLIENT_SECRET=
WHEELY_API_KEY=

# Use mock adapter for development
USE_MOCK=true
